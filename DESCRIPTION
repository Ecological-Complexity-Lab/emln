Package: emln
Type: Package
Title: Organize, Handle, and Explore Ecological Multilayer Networks
Version: 1.1.0
Date: 2026-04-20
Authors@R: c(
    person("Noa", "Frydman", role = "aut"),
    person("Shai", "Pilosof", role = c("aut", "fnd"), email = "pilos@bgu.ac.il"),
